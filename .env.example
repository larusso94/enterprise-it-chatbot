# Azure OpenAI Configuration
OPENAI_API_BASE=https://YOUR-RESOURCE.openai.azure.com/
OPENAI_API_KEY=your-api-key-here
OPENAI_DEPLOYMENT_NAME=gpt-4-deployment
OPENAI_EMBED_DEPLOYMENT=text-embedding-ada-002
OPENAI_API_VERSION=2024-02-15-preview
EMBEDDING_DIM=1536

# Azure Cosmos DB
COSMOS_ENDPOINT=https://YOUR-ACCOUNT.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key
COSMOS_DATABASE=itchatbot
COSMOS_CONTAINER_SESSIONS=sessions
COSMOS_CONTAINER_VECTORS=vstore
PARTITION_KEY=/id

# ServiceNow Configuration
# Choose ONE authentication method:

# Option 1: Basic Auth
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_USERNAME=your-username
SERVICENOW_PASSWORD=your-password

# Option 2: Bearer Token
# SERVICENOW_TOKEN=your-bearer-token

# Option 3: OAuth 2.0
# SERVICENOW_OAUTH_CLIENT_ID=your-client-id
# SERVICENOW_OAUTH_CLIENT_SECRET=your-client-secret

# ServiceNow Configuration IDs (optional)
SERVICENOW_SECURITY_REQUEST_ITEM_ID=your-catalog-item-sys-id
SERVICENOW_SECURITY_OPERATION_CENTER_ID=your-assignment-group-sys-id
SERVICENOW_TIMEOUT=30

# Microsoft Bot Framework
MICROSOFT_APP_ID=your-bot-app-id
MICROSOFT_APP_PASSWORD=your-bot-client-secret
MICROSOFT_APP_TYPE=SingleTenant
MICROSOFT_TENANT_ID=your-azure-tenant-id
BOT_FRAMEWORK_TIMEOUT=30

# Agent Configuration
AGENT_MAX_CONTEXT_TURNS=6
AGENT_MAX_TOKENS=2000
VECTOR_SEARCH_TOP_K=3

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=1
PORT=8000
CONTAINER_ENV=false
